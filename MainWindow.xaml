<Window x:Class="WindowCompanyApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Оконная компания" Height="550" Width="900"
        WindowStartupLocation="CenterScreen">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Заголовок -->
        <Border Grid.Row="0" Background="#2C3E50" Padding="10">
            <TextBlock Text="🏢 Управление оконной компанией" 
                       FontSize="20" FontWeight="Bold" Foreground="White"
                       HorizontalAlignment="Center"/>
        </Border>

        <!-- Панель навигации -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" 
                    HorizontalAlignment="Center" VerticalAlignment="Top" Margin="0,10">
            <Button x:Name="btnClients" Content="📋 Клиенты" Width="120" Height="40" 
                    Margin="5" Click="btnClients_Click" Background="#3498DB" Foreground="White"/>
            <Button x:Name="btnOrders" Content="📦 Заказы" Width="120" Height="40" 
                    Margin="5" Click="btnOrders_Click" Background="#3498DB" Foreground="White"/>
            <Button x:Name="btnProducts" Content="🪟 Продукция" Width="120" Height="40" 
                    Margin="5" Click="btnProducts_Click" Background="#3498DB" Foreground="White"/>
            <Button x:Name="btnEmployees" Content="👥 Сотрудники" Width="120" Height="40" 
                    Margin="5" Click="btnEmployees_Click" Background="#3498DB" Foreground="White"/>
        </StackPanel>

        <!-- Border для отладки - покажет, есть ли содержимое во Frame -->
        <Border Grid.Row="2" Background="LightYellow" BorderBrush="Red" BorderThickness="2">
            <Frame x:Name="MainFrame" NavigationUIVisibility="Hidden"/>
        </Border>

        <!-- Строка состояния -->
        <Border Grid.Row="3" Background="#34495E" Padding="5">
            <TextBlock x:Name="StatusText" Text="Готово" Foreground="White" FontSize="11"/>
        </Border>
    </Grid>
</Window>