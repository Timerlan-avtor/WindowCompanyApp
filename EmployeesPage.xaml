<Page x:Class="WindowCompanyApp.EmployeesPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Сотрудники">

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Text="👥 Список сотрудников" FontSize="18" FontWeight="Bold" Margin="0,0,0,10"/>

        <DataGrid x:Name="dgEmployees" Grid.Row="1" AutoGenerateColumns="True" 
                  IsReadOnly="True" Margin="0,5" AlternatingRowBackground="LightGray"/>
    </Grid>
</Page>