<Page x:Class="WindowCompanyApp.OrdersPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Заказы">

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Text="📦 Список заказов" FontSize="18" FontWeight="Bold" Margin="0,0,0,10"/>

        <DataGrid x:Name="dgOrders" Grid.Row="1" AutoGenerateColumns="True" 
                  IsReadOnly="True" Margin="0,5" AlternatingRowBackground="LightGray"/>
    </Grid>
</Page>